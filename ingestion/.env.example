# =============================================================================
# UBIK Ingestion System — Environment Configuration
# Hippocampal Node (Mac Mini M4 Pro, macOS)
# Copy to .env and fill in values.
# =============================================================================

# --- ChromaDB (local, on this node) -----------------------------------------
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_TOKEN=

# --- Neo4j (local, on this node) --------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- MCP Server (local, on this node) ---------------------------------------
MCP_HOST=localhost
MCP_PORT=8080

# --- Somatic Node (for WhisperX audio transcription only) -------------------
SOMATIC_HOST=100.79.166.114
SOMATIC_WHISPER_PORT=9100

# --- Google Drive (optional) ------------------------------------------------
GDRIVE_CREDENTIALS_PATH=/Volumes/990PRO 4T/UBIK/config/gdrive_credentials.json
GDRIVE_TOKEN_PATH=/Volumes/990PRO 4T/UBIK/config/gdrive_token.json
GDRIVE_UBIK_FOLDERS=

# Drive folder IDs for fetch_sources.py --gdrive (one per source bucket;
# leave empty to skip that bucket). Credentials/token paths above are
# gitignored — never commit them.
UBIK_GDRIVE_FOLDER_TACTIQ=
UBIK_GDRIVE_FOLDER_GEMINI=
UBIK_GDRIVE_FOLDER_FIREFLIES=
UBIK_GDRIVE_FOLDER_LETTERS=
UBIK_GDRIVE_FOLDER_MEMORY_NOTES=
UBIK_GDRIVE_FOLDER_CONSTITUTION=

# --- Identity ---------------------------------------------------------------
GINES_IDENTIFIER=Gines
GINES_ALIASES=Gasu,Dad,Abuelo
GINES_EMAIL_ADDRESSES=

# --- Logging & Paths --------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/Volumes/990PRO 4T/UBIK/logs/ingestion/
UBIK_ROOT=/Volumes/990PRO 4T/UBIK

# --- Audio Processor --------------------------------------------------------
# Whisper model for local CPU fallback (tiny/base/small — large is slow on CPU)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# --- Enrichment LLM Endpoints (config/ingestion_config.py) -------------------
# Full base URL wins over composed values. Composition order:
# SOMATIC_VLLM_URL > SOMATIC_TAILSCALE_IP > SOMATIC_LAN_IP > hostname.
# Per-tier overrides: sensitive content must stay on self-hosted endpoints.
SOMATIC_VLLM_URL=
SOMATIC_TAILSCALE_IP=
SOMATIC_TAILSCALE_HOSTNAME=ubik-somatic
SOMATIC_LAN_IP=
SOMATIC_VLLM_LAN_URL=
VLLM_PORT=8002
UBIK_SENSITIVE_LLM_URL=
UBIK_STANDARD_LLM_URL=
UBIK_ENRICHMENT_MODEL=
UBIK_LLM_TIMEOUT_SECONDS=120
# Privacy tiers (from known_persons.yaml: private/therapy/family/business)
# allowed on the standard endpoint. Default empty = ALL tiers route to the
# sensitive endpoint (fail-safe). Example: UBIK_STANDARD_PRIVACY_TIERS=business
UBIK_STANDARD_PRIVACY_TIERS=

# --- Ingestion Workspace & Gate 1 (config/ingestion_config.py) ---------------
# Root of sources/ enriched/ pending_review/ approved/ quarantine/ registry/
# qa/ logs/ (default: the ingestion/ directory itself)
UBIK_INGESTION_ROOT=
# Enrichment confidence >= this is auto-approved into approved/
UBIK_GATE_AUTO_APPROVE=0.85
# Enrichment confidence < this is quarantined; in between -> pending_review/
UBIK_GATE_QUARANTINE_BELOW=0.60
# Version tag stamped on every enrichment output
UBIK_PROMPT_VERSION=v1.0.0

# --- Enrichment client (enrich.py / spike_enrichment.py) ---------------------
# Prompt template (placeholders {{KNOWN_PERSONS}} {{SOURCE_HINTS}} {{SCHEMA}}
# {{CONTENT}}) and the JSON Schema used to validate model output. Defaults are
# relative to the ingestion root; override only to point elsewhere.
UBIK_ENRICHMENT_PROMPT=
UBIK_ENRICHMENT_SCHEMA=
# LLM sampling + retry/backoff for the enrichment call
UBIK_LLM_TEMPERATURE=0.1
UBIK_LLM_MAX_TOKENS=4096
UBIK_LLM_MAX_RETRIES=3
UBIK_LLM_RETRY_BASE_SECONDS=1.0
UBIK_LLM_RETRY_MAX_SECONDS=30.0
