# =============================================================================
# DeepSeek RAG System - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.

# -----------------------------------------------------------------------------
# Ollama Service
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
DEEPSEEK_MODEL=deepseek-r1:14b

# -----------------------------------------------------------------------------
# Jina AI Embeddings (get key at https://jina.ai)
# -----------------------------------------------------------------------------
JINA_API_KEY=your-jina-api-key-here
JINA_MODEL=jina-embeddings-v2-base-en

# -----------------------------------------------------------------------------
# Storage - defaults to ./chroma_embeddings relative to project root
# Override to use an absolute path on a specific drive
# -----------------------------------------------------------------------------
# EMBEDDINGS_BASE_DIR=/Volumes/990PRO 4T/DeepSeek/chroma_embeddings

# -----------------------------------------------------------------------------
# RAG Tuning
# -----------------------------------------------------------------------------
CHUNK_SIZE=3000
CHUNK_OVERLAP=500
EMBEDDING_BATCH_SIZE=10
EMBEDDING_BATCH_DELAY=1.0
RAG_K=5
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
